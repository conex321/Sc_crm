# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored.

# ─── Supabase ────────────────────────────────────────────────────────
# Project URL: https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Anon / publishable key (safe for browser; respects RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server-only, bypasses RLS — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for Drizzle migrations (server-only)
# Format: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=

# ─── Auth ────────────────────────────────────────────────────────────
# Restrict Google SSO to this email domain (D-007)
ALLOWED_EMAIL_DOMAIN=schoolconex.com

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Phase 2: Google Drive integration ───────────────────────────────
# OAuth client (Web application) for per-user Drive auth (drive.file scope).
# Console: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${NEXT_PUBLIC_SITE_URL}/auth/google-drive-callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Service account JSON key (single-line stringified). Used for system-level
# Drive operations: copying templates, status reconciliation. Share both
# folders below with this account's email (read for templates, write for
# generated).
GOOGLE_SERVICE_ACCOUNT_KEY=

# Drive folder IDs. Both must be shared with the service account.
GOOGLE_DRIVE_TEMPLATES_FOLDER_ID=
GOOGLE_DRIVE_GENERATED_FOLDER_ID=

# ─── Phase 3: Dialpad integration ────────────────────────────────────
# Console: Dialpad app → Admin Settings → Integrations → API → API Keys
DIALPAD_API_KEY=
# Optional: Dialpad webhook signing secret (for HMAC verification)
DIALPAD_WEBHOOK_SECRET=
# Webhook URL to register in Dialpad: ${NEXT_PUBLIC_SITE_URL}/api/webhooks/dialpad

# ─── Phase 5: Stripe integration ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Webhook URL: ${NEXT_PUBLIC_SITE_URL}/api/webhooks/stripe

# ─── Phase 5: Mailshake integration ──────────────────────────────────
MAILSHAKE_API_KEY=
MAILSHAKE_WEBHOOK_SECRET=
# Webhook URL: ${NEXT_PUBLIC_SITE_URL}/api/webhooks/mailshake

# ─── Phase 6: WhatsApp (BSP) integration ─────────────────────────────
# Choose one BSP and fill its credentials. Default scaffolding is for
# Twilio; swap to Meta Cloud API or another BSP as needed.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
# Webhook URL: ${NEXT_PUBLIC_SITE_URL}/api/webhooks/whatsapp

# ─── Inngest (Phase 2+ background jobs) ──────────────────────────────
# In dev: start `npx inngest-cli@latest dev` in another terminal — keys
# can be left blank locally. In prod: get from app.inngest.com.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
