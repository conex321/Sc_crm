# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored.

# ─── Supabase ────────────────────────────────────────────────────────
# Project URL: https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Anon key (safe for browser; respects RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server-only, bypasses RLS — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for Drizzle migrations (server-only)
# Format: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=

# ─── Auth ────────────────────────────────────────────────────────────
# Restrict Google SSO to this email domain (D-007)
ALLOWED_EMAIL_DOMAIN=schoolconex.com

# ─── App ─────────────────────────────────────────────────────────────
# Public site URL (used for OAuth callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
